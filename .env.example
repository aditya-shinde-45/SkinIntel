# SkinIntel Backend — Environment Variables
# Copy this file to .env and fill in values for your environment.

# ── Model ──────────────────────────────────────────────────────────────────────
# Filesystem path to the trained Keras model file (.keras format)
MODEL_PATH=models/model.keras

# Semantic version string exposed in every /api/v1/analyze response meta field
MODEL_VERSION=1.0.0

# ── Dataset ────────────────────────────────────────────────────────────────────
# Filesystem path to the skincare products CSV dataset
PRODUCTS_CSV_PATH=data/products.csv

# ── Server ─────────────────────────────────────────────────────────────────────
# Port the server listens on (default: 5000)
PORT=5000

# Runtime environment: dev | staging | prod
# In prod mode debug is disabled and verbose error details are suppressed
ENV=dev

# ── CORS ───────────────────────────────────────────────────────────────────────
# Allowed CORS origin for all routes. Use * to allow all origins (default: *)
ALLOWED_ORIGIN=*

# ── Image Validation ───────────────────────────────────────────────────────────
# Maximum accepted image upload size in megabytes (default: 10)
MAX_IMAGE_SIZE_MB=10

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Per-IP sliding-window rate limit on /api/v1/analyze (requests per minute, default: 30)
RATE_LIMIT_PER_MINUTE=30

# ── Inference ──────────────────────────────────────────────────────────────────
# Minimum softmax confidence score; below this threshold the API falls back to
# general_skincare and sets low_confidence=true in the response (default: 0.40)
CONFIDENCE_THRESHOLD=0.40

# ── LLM (optional) ─────────────────────────────────────────────────────────────
# Option 1: Ollama (local, free — recommended)
# Install: https://ollama.com  then run: ollama pull mistral
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Option 2: OpenAI (cloud, requires API key)
# If OLLAMA_URL is reachable, Ollama takes priority over OpenAI.
OPENAI_API_KEY=
