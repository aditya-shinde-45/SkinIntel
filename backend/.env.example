# SkinIntel Backend — Environment Variables
# Copy this file to .env and fill in values for your environment.

# ── Model ──────────────────────────────────────────────────────────────────────
# Filesystem path to the trained Keras model file (.keras format)
MODEL_PATH=models/model.keras

# Semantic version string exposed in every /api/v1/analyze response meta field
MODEL_VERSION=1.0.0

# ── Dataset ────────────────────────────────────────────────────────────────────
# Filesystem path to the skincare products CSV dataset
PRODUCTS_CSV_PATH=data/products.csv

# ── Server ─────────────────────────────────────────────────────────────────────
# Port the server listens on (default: 5000)
PORT=5000

# Runtime environment: dev | staging | prod
# In prod mode debug is disabled and verbose error details are suppressed
ENV=dev

# ── CORS ───────────────────────────────────────────────────────────────────────
# Allowed CORS origin for all routes. Use * to allow all origins (default: *)
ALLOWED_ORIGIN=*

# ── Image Validation ───────────────────────────────────────────────────────────
# Maximum accepted image upload size in megabytes (default: 10)
MAX_IMAGE_SIZE_MB=10

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# Per-IP sliding-window rate limit on /api/v1/analyze (requests per minute, default: 30)
RATE_LIMIT_PER_MINUTE=30

# ── Inference ──────────────────────────────────────────────────────────────────
# Minimum softmax confidence score; below this threshold the API falls back to
# general_skincare and sets low_confidence=true in the response (default: 0.40)
CONFIDENCE_THRESHOLD=0.40

# ── LLM (optional) ─────────────────────────────────────────────────────────────
# Option 1: Ollama (local, free — recommended)
# Install: https://ollama.com  then run: ollama pull mistral
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Vision model for skin condition detection (single-model approach)
# Recommended: llava-phi3 (balanced), llava (stronger), moondream (lighter)
OLLAMA_VISION_MODEL=llava-phi3
OLLAMA_VISION_MODEL_FALLBACKS=llava,moondream,llava:13b

# Condition confidence thresholds (0-1). Lower catches more but can add false positives.
CONDITION_THRESHOLD=0.20
CONDITION_THRESHOLD_ACNE=0.08
CONDITION_THRESHOLD_DARK_CIRCLES=0.18
CONDITION_THRESHOLD_HYPERPIGMENTATION=0.18
CONDITION_THRESHOLD_BLACKHEADS=0.16
CONDITION_THRESHOLD_WRINKLES=0.16
CONDITION_THRESHOLD_OILY_SKIN=0.18
CONDITION_THRESHOLD_DRY_SKIN=0.18
CONDITION_FOCUSED_RESCUE_MARGIN=0.06

# Option 2: OpenAI (cloud, requires API key)
# If OLLAMA_URL is reachable, Ollama takes priority over OpenAI.
OPENAI_API_KEY=

# ── Authentication ──────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens — change this in production!
JWT_SECRET=skinintel-dev-secret-change-in-prod

# JWT token expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# ── DynamoDB ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
DYNAMODB_TABLE=skinintel_users

# For DynamoDB Local: DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_ENDPOINT=

# AWS credentials (if not using IAM role or ~/.aws/credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
