# SkinIntel Backend — Environment Variables
# Copy this file to .env and fill in real values.

# ── Model ──────────────────────────────────────────────────────────────────────
MODEL_PATH=models/skin_concern_model.keras
CONCERN_MODEL_PATH=models/skin_concern_model.keras
MODEL_VERSION=1.0.0

# ── Dataset ────────────────────────────────────────────────────────────────────
PRODUCTS_CSV_PATH=data/skincare_products_clean.csv

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
ENV=prod

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=*

# ── Image Validation ───────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Inference ──────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.40

# ── Authentication ──────────────────────────────────────────────────────────────
JWT_SECRET=change-this-in-production
JWT_EXPIRY_HOURS=24

# ── DynamoDB ────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
DYNAMODB_TABLE=skinintel_users
DYNAMODB_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
